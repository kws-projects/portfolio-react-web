{
  "name": "portfolio-react-web",
  "private": true,
  "version": "2.0.1",
  "type": "module",
  "scripts": {
    "dev": "cp .env.development.local .env && vite",
    "prod": "cp .env.production.local .env && vite",
    "build:dev": "cp .env.development.local .env && vite build",
    "build:prod": "cp .env.production.local .env && vite build && yarn sentry:sourcemaps",
    "lint": "eslint .",
    "prettier": "npx prettier . --write",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "upload-source-maps": "npx @sentry/wizard@latest -i sourcemaps",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org kenneth-wong --project portfolio-react-web ./dist && sentry-cli sourcemaps upload --org kenneth-wong --project portfolio-react-web ./dist",
    "prepare": "husky",
    "pre-commit": "lint-staged",
    "pre-push": "tsc",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@sentry/react": "^10.55.0",
    "@tanstack/react-query": "^5.100.14",
    "axios": "^1.16.1",
    "dayjs": "^1.11.21",
    "dompurify": "^3.4.7",
    "framer-motion": "^12.40.0",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "monaco-editor": "^0.55.1",
    "p5": "^1.11.13",
    "qs": "^6.15.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-ga4": "^3.0.1",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.16.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@eslint/js": "^9.39.4",
    "@sentry/cli": "^3.4.3",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/p5": "^1.7.6",
    "@types/qs": "^6.15.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.1",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^7.3.3",
    "vitest": "^4.1.7"
  },
  "resolutions": {
    "vitest/vite": "^7.3.3"
  }
}
