# Required environment variables (template).
# Copy to `.env.development.local` and `.env.production.local` and fill in real
# values, or run `yarn env:setup`. Only VITE_-prefixed vars are exposed to the
# client and are inlined into the bundle at build time.
#
# Note: VITE_APP_VERSION and VITE_SENTRY_RELEASE are auto-derived from
# package.json in vite.config.ts — do NOT set them manually.

# App
VITE_APP_NAME="Portfolio"

# ── API ──────────────────────────────────────────────────────────────────────
VITE_PORTFOLIO_API_BASE_URL="http://localhost:3000/api"
VITE_STATIC_FILE_BASE_URL="https://static.kwwdev.com"
VITE_CV_URL="https://kws-note.notion.site/cv"
VITE_GITHUB_RELEASE_URL="https://github.com/kws-projects/portfolio-react-web/releases"

# ── Analytics (Google Analytics 4) ────────────────────────────────────────────
# Set ENABLED=true and provide a Measurement ID (G-XXXXXXXXXX) to activate.
VITE_ANALYTICS_ENABLED="false"
VITE_GA_MEASUREMENT_ID=""
# Enables GA4 DebugView (set true only in development / staging).
VITE_GA_DEBUG_MODE="false"

# ── Error monitoring (Sentry) ────────────────────────────────────────────────
# Set ENABLED=true and provide a DSN to activate.
VITE_SENTRY_ENABLED="false"
VITE_SENTRY_DSN=""
# Defaults to Vite MODE (development / production) if omitted.
VITE_SENTRY_ENVIRONMENT=""
# Performance: fraction of transactions to capture (0–1). Default 0.1 (10%).
VITE_SENTRY_TRACES_SAMPLE_RATE="0.1"
# Session Replay: fraction of normal sessions recorded (0–1). Default 0.
VITE_SENTRY_REPLAYS_SAMPLE_RATE="0"
# Session Replay: fraction of error sessions recorded (0–1). Default 1.
VITE_SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE="1"

# ── Sentry source-map upload (build-time only, NOT VITE_ prefixed) ───────────
# These are used by @sentry/vite-plugin during `yarn build` to upload source
# maps. They are NOT exposed to the client bundle.
# SENTRY_AUTH_TOKEN=""
# SENTRY_ORG=""
# SENTRY_PROJECT=""
